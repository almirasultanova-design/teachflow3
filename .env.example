# Backend (server/.env)
PORT=4000
DATABASE_PATH=./data/lyricling.db
UPLOADS_DIR=./data/uploads
PUBLIC_BASE_URL=http://localhost:4000

# Where the frontend is served from (used for CORS + cookie origin).
CLIENT_ORIGIN=http://localhost:5173

# Authentication. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
AUTH_COOKIE_NAME=tf_auth
# Set to true behind HTTPS in production.
COOKIE_SECURE=false
# 30 days by default.
AUTH_TOKEN_TTL_SECONDS=2592000

# OpenAI (optional). When omitted the server falls back to deterministic mock translations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# YouTube Data API v3 (optional). When omitted the catalog import falls back to virtual mode.
# Create one at https://console.cloud.google.com -> APIs & Services -> Credentials.
YOUTUBE_API_KEY=

# Frontend (client/.env)
VITE_API_URL=http://localhost:4000
